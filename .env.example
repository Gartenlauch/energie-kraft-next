@'
# Runtime
NEXT_PUBLIC_SITE_ENV=local
NEXT_PUBLIC_CANONICAL_BASE_URL=https://www.energie-kraft.de

# Firebase Web SDK
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=energie-kraft-next.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=energie-kraft-next
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=energie-kraft-next.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Emulator Suite
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
'@ | Set-Content -Encoding utf8 .env.example